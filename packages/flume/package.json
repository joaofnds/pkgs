{
	"name": "@joaofnds/flume",
	"version": "0.0.0",
	"license": "MIT",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./redis": {
			"types": "./dist/redis.d.ts",
			"default": "./dist/redis.js"
		},
		"./testing": {
			"types": "./dist/testing.d.ts",
			"default": "./dist/testing.js"
		}
	},
	"author": "joaofnds <joaofnds@joaofnds.com>",
	"repository": {
		"url": "https://github.com/joaofnds/pkgs.git",
		"type": "git",
		"directory": "packages/flume"
	},
	"scripts": {
		"prebuild": "rm -rf dist",
		"build": "tsc --build",
		"pretest": "docker compose up -d",
		"test": "vitest run",
		"posttest": "docker compose down",
		"bench": "docker compose up -d && tsx benchmark/throughput.bench.ts; docker compose down"
	},
	"peerDependencies": {
		"@joaofnds/throughput": "^0.6.6",
		"redis": "^6.0.0"
	},
	"peerDependenciesMeta": {
		"@joaofnds/throughput": {
			"optional": true
		},
		"redis": {
			"optional": true
		}
	},
	"devDependencies": {
		"@joaofnds/throughput": "workspace:^",
		"@types/node": "^24.13.2",
		"bullmq": "^5.78.1",
		"ioredis": "^5.11.1",
		"redis": "^6.0.0",
		"tsx": "^4.19.2",
		"typescript": "^6.0.3"
	}
}
